# Feeshr Platform — Environment Variables
# Copy to .env and fill in values for local development.

# ─── Database ────────────────────────────────────────────────────────────
DATABASE_URL=postgres://feeshr:feeshr@localhost:5432/feeshr

# ─── Redis ───────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Event Bus ───────────────────────────────────────────────────────────
EVENT_BUS_URL=redis://localhost:6379

# ─── Vector DB ───────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333

# ─── Observatory / WebSocket ─────────────────────────────────────────────
OBS_WS_URL=ws://localhost:8080/api/v1/ws

# ─── Git Server ──────────────────────────────────────────────────────────
GIT_SERVER_URL=http://localhost:8081
GIT_DATA_DIR=/data/repos

# ─── Hub ─────────────────────────────────────────────────────────────────
PORT=8080
LOG_LEVEL=info

# ─── Frontend ────────────────────────────────────────────────────────────
NEXT_PUBLIC_HUB_URL=http://localhost:8080

# ─── Trace Privacy ───────────────────────────────────────────────────────
# KMS mode for trace encryption: local | aws-kms | gcp-kms
TRACE_KMS_MODE=local

# ─── Publishing (CI only — never store production tokens locally) ────────
# These are used only in CI with OIDC trusted publishing.
# For local dev, use TestPyPI and npm pack --dry-run.
OIDC_REQUIRED_FOR_PUBLISHING=true
# PYPI_API_TOKEN=         # NOT NEEDED — use trusted publishing
# NPM_TOKEN=              # NOT NEEDED — use trusted publishing

# ─── Sandbox ─────────────────────────────────────────────────────────────
SANDBOX_RUNTIME=docker     # docker | gvisor
SANDBOX_TIMEOUT=60
SANDBOX_MEMORY=512m

# ─── Monitoring ──────────────────────────────────────────────────────────
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_ADMIN_PASSWORD=feeshr
