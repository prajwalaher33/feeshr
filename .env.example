# Feeshr Platform — Environment Variables
# Copy to .env and fill in values for local development.
#
# For production deployment, set these in your hosting provider's dashboard:
#   - Vercel:  Project Settings > Environment Variables
#   - Fly.io:  fly secrets set KEY=VALUE
#   - Supabase: Settings > Database > Connection string

# ─── Database ────────────────────────────────────────────────────────────
# Local: docker-compose Postgres
DATABASE_URL=postgres://feeshr:feeshr@localhost:5432/feeshr
# Production (Supabase): postgres://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# ─── Redis (optional — not required for core functionality) ──────────────
REDIS_URL=redis://localhost:6379

# ─── Event Bus (optional) ───────────────────────────────────────────────
EVENT_BUS_URL=redis://localhost:6379

# ─── Vector DB (optional — for semantic search) ─────────────────────────
QDRANT_URL=http://localhost:6333

# ─── Observatory / WebSocket ─────────────────────────────────────────────
OBS_WS_URL=ws://localhost:8080/api/v1/ws

# ─── Git Server (optional) ──────────────────────────────────────────────
GIT_SERVER_URL=http://localhost:8081
GIT_DATA_DIR=/data/repos

# ─── Hub API Server ─────────────────────────────────────────────────────
PORT=8080
LOG_LEVEL=info

# ─── Frontend (Next.js) ─────────────────────────────────────────────────
# Local development:
NEXT_PUBLIC_HUB_URL=http://localhost:8080
# Production (set in Vercel dashboard):
# NEXT_PUBLIC_HUB_URL=https://api.feeshr.com

# Internal hub URL for SSR (Docker or production):
# HUB_INTERNAL_URL=http://hub:8080

# ─── Agents Service ────────────────────────────────────────────────────
HUB_URL=http://localhost:8080
# Production (Fly.io): https://api.feeshr.com

# ─── Trace Privacy ──────────────────────────────────────────────────────
TRACE_KMS_MODE=local

# ─── Quantum-Safe Configuration ─────────────────────────────────────────
PQ_SIGNATURE_DEFAULT=sphincs-sha3-256f
PQ_SIGNATURE_HYBRID_MODE=true
PQ_HMAC_DEPRECATION_DATE=
PQ_TLS_ENABLED=true
PQ_OIDC_MONITORING=true

# ─── Sandbox (optional) ─────────────────────────────────────────────────
SANDBOX_RUNTIME=docker
SANDBOX_TIMEOUT=60
SANDBOX_MEMORY=512m

# ─── Publishing (CI only) ───────────────────────────────────────────────
OIDC_REQUIRED_FOR_PUBLISHING=true

# ─── Monitoring (local Docker only) ─────────────────────────────────────
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_ADMIN_PASSWORD=feeshr
