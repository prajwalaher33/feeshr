# Feeshr Platform — Environment Variables
# Copy to .env and fill in values for local development.
#
# For production deployment, set these in your hosting provider's dashboard:
#   - Vercel:  Project Settings > Environment Variables
#   - Fly.io:  fly secrets set KEY=VALUE
#   - Supabase: Settings > Database > Connection string

# ─── Database ────────────────────────────────────────────────────────────
# Local: docker-compose Postgres
DATABASE_URL=postgres://feeshr:feeshr@localhost:5432/feeshr
# Production (Supabase): postgres://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# ─── Redis (optional — not required for core functionality) ──────────────
REDIS_URL=redis://localhost:6379

# ─── Event Bus (optional) ───────────────────────────────────────────────
EVENT_BUS_URL=redis://localhost:6379

# ─── Vector DB (optional — for semantic search) ─────────────────────────
QDRANT_URL=http://localhost:6333

# ─── Observatory / WebSocket ─────────────────────────────────────────────
OBS_WS_URL=ws://localhost:8080/api/v1/ws

# ─── Git Server (optional) ──────────────────────────────────────────────
GIT_SERVER_URL=http://localhost:8081
GIT_DATA_DIR=/data/repos

# ─── Hub API Server ─────────────────────────────────────────────────────
PORT=8080
LOG_LEVEL=info

# ─── Hub: resilience knobs ──────────────────────────────────────────────
# Database connection pool. Defaults are tuned for a small VM; raise for
# heavier workloads. Idle/lifetime settings recycle connections so a flaky
# network never leaves the pool full of dead sockets.
DB_MAX_CONNECTIONS=20
DB_MIN_CONNECTIONS=2
DB_ACQUIRE_TIMEOUT_SECS=5
DB_IDLE_TIMEOUT_SECS=600
DB_MAX_LIFETIME_SECS=1800

# Per-request hard limits. Streaming routes (/ws, /desktop/ws) are exempt
# from the timeout; the body limit applies everywhere.
MAX_REQUEST_BODY_BYTES=2097152   # 2 MB
REQUEST_TIMEOUT_SECS=30

# CORS allowlist. Empty (or "*") = wide-open Any (dev default). Production
# should pin to your frontend origins, comma-separated.
# CORS_ALLOWED_ORIGINS=https://feeshr.com,https://www.feeshr.com
CORS_ALLOWED_ORIGINS=

# ─── Frontend (Next.js) ─────────────────────────────────────────────────
# Local development (browser-side URLs):
NEXT_PUBLIC_HUB_URL=http://localhost:8080
NEXT_PUBLIC_GIT_SERVER_URL=http://localhost:8081
# Production (set in Vercel dashboard):
# NEXT_PUBLIC_HUB_URL=https://api.feeshr.com
# NEXT_PUBLIC_GIT_SERVER_URL=https://git.feeshr.com

# Internal URLs for SSR (Docker or production). Compose uses these to
# avoid round-tripping through the public hostname during server render.
# HUB_INTERNAL_URL=http://hub:8080
# GIT_SERVER_INTERNAL_URL=http://git-server:8081

# ─── Agents Service ────────────────────────────────────────────────────
HUB_URL=http://localhost:8080
# Production (Fly.io): https://api.feeshr.com

# ─── Trace Privacy ──────────────────────────────────────────────────────
TRACE_KMS_MODE=local

# ─── Quantum-Safe Configuration ─────────────────────────────────────────
PQ_SIGNATURE_DEFAULT=sphincs-sha3-256f
PQ_SIGNATURE_HYBRID_MODE=true
PQ_HMAC_DEPRECATION_DATE=
PQ_TLS_ENABLED=true
PQ_OIDC_MONITORING=true

# ─── Sandbox (optional) ─────────────────────────────────────────────────
SANDBOX_RUNTIME=docker
SANDBOX_TIMEOUT=60
SANDBOX_MEMORY=512m

# ─── Publishing (CI only) ───────────────────────────────────────────────
OIDC_REQUIRED_FOR_PUBLISHING=true

# ─── Monitoring (local Docker only) ─────────────────────────────────────
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_ADMIN_PASSWORD=feeshr
